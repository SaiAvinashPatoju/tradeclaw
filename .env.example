# ── Binance API ─────────────────────────────────────────────────────────
# Obtain from https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://tradeclaw:changeme@localhost:5432/tradeclaw

# ── Firebase / FCM ───────────────────────────────────────────────────────
FCM_PROJECT_ID=your_firebase_project_id
# Path to the service account JSON (relative to project root or absolute).
# Generate from Firebase Console → Project Settings → Service Accounts.
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# Example: http://localhost:3000,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Admin API key ─────────────────────────────────────────────────────────
# When set, the X-API-Key header is required for write/admin endpoints.
# Leave empty to disable auth (development only).
TRADECLAW_API_KEY=

# ── Runtime engine defaults (optional) ───────────────────────────────────
TRADECLAW_DATA_SOURCE_MODE=simulator
TRADECLAW_ALGORITHM_PROFILE=mid
